{
    "multipart": [
        {
            "when": {
                "hasface": true,
                "renderface": "x"
            },
            "apply": {
                "model": "mystcraft-sc:block/linkportal_ew"
            }
        },
        {
            "when": {
                "hasface": true,
                "renderface": "y"
            },
            "apply": {
                "model": "mystcraft-sc:block/linkportal_ud"
            }
        },
        {
            "when": {
                "hasface": true,
                "renderface": "z"
            },
            "apply": {
                "model": "mystcraft-sc:block/linkportal_ns"
            }
        },
        {
            "when": {
                "hasface": false
            },
            "apply": {
                "model": "mystcraft-sc:block/linkportal_full"
            }
        }
    ]
}