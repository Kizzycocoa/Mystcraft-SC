{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:block_state",
    "block_state_property": "color",
    "cases": [
      { "when": "maroon",     "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_maroon" } },
      { "when": "red",        "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_red" } },
      { "when": "olive",      "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_olive" } },
      { "when": "yellow",     "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_yellow" } },
      { "when": "dark_green", "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_dark_green" } },
      { "when": "green",      "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_green" } },
      { "when": "teal",       "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_teal" } },
      { "when": "cyan",       "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_cyan" } },
      { "when": "navy",       "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_navy" } },
      { "when": "blue",       "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_blue" } },
      { "when": "purple",     "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_purple" } },
      { "when": "magenta",    "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_magenta" } },
      { "when": "black",      "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_black" } },
      { "when": "grey",       "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_grey" } },
      { "when": "silver",     "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_silver" } },
      { "when": "white",      "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_white" } },
      { "when": "orange",     "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_orange" } },
      { "when": "lime",       "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_lime" } },
      { "when": "citrus",     "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_citrus" } },
      { "when": "pink",       "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_pink" } },
      { "when": "dark_grey",  "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_dark_grey" } },
      { "when": "baby_blue",  "model": { "type": "minecraft:model", "model": "mystcraft-sc:block/crystal/crystal_baby_blue" } }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "mystcraft-sc:block/crystal/crystal_baby_blue"
    }
  }
}